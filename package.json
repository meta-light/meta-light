{
  "name": "meta-light",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/web",
    "apps/crm",
    "apps/carpcap",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "build:web": "turbo run build --filter=web",
    "dev:web": "turbo run dev --filter=web"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "overrides": {
    "csv-stringify": "5.6.5",
    "csv-parse": "4.16.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
