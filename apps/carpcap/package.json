{
  "name": "carpcap",
  "version": "1.0.0",
  "description": "CarpCap",
  "main": "src/index.ts",
  "scripts": {
    "start": "NODE_OPTIONS='--no-deprecation' npx tsx src/index.ts",
    "check-types": "tsc --noEmit",
    "backfill": "npx tsx src/scripts/backfill.ts",
    "backfill:0xmetalight": "npx tsx src/scripts/backfill.ts",
