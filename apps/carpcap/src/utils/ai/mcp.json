{
  "mcpServers": {
    "coingecko_mcp": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.api.coingecko.com/mcp"
      ]
    },
    "token-metrics": {
      "url": "https://mcp.tokenmetrics.com",
      "headers": {
        "x-api-key": "YOUR_API_KEY"
      }
    },
    "web3-research-mcp": {
      "command": "npx",
      "args": ["-y", "web3-research-mcp@latest"]
    },
    "mcpServers": {
      "phantom-docs": {
        "type": "sse",
        "url": "https://docs.phantom.com/mcp"
      }
    },
    "macrocosmos": {
      "command": "uvx",
      "args": ["macrocosmos-mcp"],
      "env": {
        "MC_API": "<insert-your-api-key-here>"
      }
    }
  }
}