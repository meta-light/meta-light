# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo root .gitignore — patterns are unanchored so they apply to every package
# (web, crm, carpcap, swap rate, ...). Package-specific rules are scoped by path below.

# dependencies
node_modules/
/.pnp
.pnp.*
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn/install-state.gz

# testing / coverage
coverage/

# next.js
.next/
out/

# production / build output
build/
dist/

# misc
.DS_Store
Thumbs.db
*.pem

# editors
.idea/
*.swp
*.swo

# logs / debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# root scratch
/repos

# ---- carpcap (Node + Rust + OCR/PDF tooling) ----
carpcap/package-lock.json
carpcap/yarn.lock
carpcap/.tesseract/
carpcap/pdfjs-dist/
carpcap/rust/target/
carpcap/rust/Cargo.lock
!carpcap/documents/.gitkeep
!carpcap/output/.gitkeep

crm/crm.db

.agents/twitter-accounts.json

carpcap/src/backups

carpcap/src/services/ventures

carpcap/src/services/ventures/Rubric.xlsx